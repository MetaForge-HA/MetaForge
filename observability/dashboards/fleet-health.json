{
  "uid": "metaforge-fleet-health",
  "title": "MetaForge Fleet Health",
  "tags": ["metaforge", "fleet", "telemetry", "iot"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Device Count by Status",
      "description": "Number of devices by current status (online, offline, error)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count by (status) (metaforge_telemetry_lag_seconds{device_id=~\"$device_group\"})",
          "legendFormat": "{{status}}",
          "refId": "A"
        },
        {
          "expr": "count(metaforge_mqtt_messages_received_total{device_id=~\"$device_group\"} unless absent_over_time(metaforge_mqtt_messages_received_total{device_id=~\"$device_group\"}[5m]))",
          "legendFormat": "online",
          "refId": "B"
        },
        {
          "expr": "count(absent_over_time(metaforge_mqtt_messages_received_total{device_id=~\"$device_group\"}[5m]))",
          "legendFormat": "offline",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "online" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "offline" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Telemetry Ingestion Rate",
      "description": "Telemetry messages ingested per second, grouped by device group",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (topic) (rate(metaforge_mqtt_messages_received_total{device_id=~\"$device_group\"}[5m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(metaforge_telemetry_ingestion_total{status=\"success\"}[5m]))",
          "legendFormat": "successful ingestions/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "lineWidth": 2
          },
          "unit": "msg/s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      }
    },
    {
      "id": 3,
      "title": "Anomaly Indicators",
      "description": "Count of sensors currently reporting out-of-range values",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(metaforge_telemetry_ingestion_errors_total{error_type=\"malformed\"}) or vector(0)",
          "legendFormat": "malformed readings",
          "refId": "A"
        },
        {
          "expr": "sum(rate(metaforge_telemetry_ingestion_errors_total[5m])) or vector(0)",
          "legendFormat": "error rate/s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(metaforge_telemetry_ingestion_total{status=\"error\"}[5m])) / sum(rate(metaforge_telemetry_ingestion_total[5m])) * 100 or vector(0)",
          "legendFormat": "error %",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Per-Device Drill-down",
      "description": "Per-device table showing last seen time, status, and telemetry rate",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "metaforge_telemetry_lag_seconds{device_id=~\"$device_group\"}",
          "legendFormat": "{{device_id}}",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "rate(metaforge_mqtt_messages_received_total{device_id=~\"$device_group\"}[5m])",
          "legendFormat": "{{device_id}}",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "time() - metaforge_telemetry_lag_seconds{device_id=~\"$device_group\"}",
          "legendFormat": "{{device_id}}",
          "refId": "C",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 60 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "device_id" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ],
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        }
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        }
      ]
    },
    {
      "id": 5,
      "title": "MQTT Connection Health",
      "description": "Connected versus disconnected devices over time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(rate(metaforge_mqtt_messages_received_total{device_id=~\"$device_group\"}[1m]) > 0)",
          "legendFormat": "connected",
          "refId": "A"
        },
        {
          "expr": "count(rate(metaforge_mqtt_messages_received_total{device_id=~\"$device_group\"}[1m]) == 0) or vector(0)",
          "legendFormat": "disconnected",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "connected" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "disconnected" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 6,
      "title": "TSDB Write Latency",
      "description": "Histogram of telemetry write duration to the time-series database",
      "type": "histogram",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(metaforge_telemetry_router_duration_seconds_bucket{device_type=~\"$device_group\"}[5m])",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        },
        {
          "expr": "histogram_quantile(0.95, rate(metaforge_telemetry_router_duration_seconds_bucket{device_type=~\"$device_group\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(metaforge_telemetry_router_duration_seconds_bucket{device_type=~\"$device_group\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "color": {
            "mode": "scheme",
            "exponent": 0.5
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "bucketOffset": 0,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "stacking": {
          "mode": "normal",
          "group": "A"
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(metaforge_mqtt_messages_received_total, device_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Device Group",
        "multi": true,
        "name": "device_group",
        "options": [],
        "query": {
          "query": "label_values(metaforge_mqtt_messages_received_total, device_id)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "version": 1
}
